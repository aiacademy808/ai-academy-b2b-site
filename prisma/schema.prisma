generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id               Int      @id @default(autoincrement())
  slug             String   @unique
  name             String
  tagline          String
  heroTitle        String
  heroSlogan       String   @db.Text
  accentColor      String   @default("#00e5ff")
  kpiItems         Json     @default("[]")    // [{value: "6-8×", label: "Ускорение", source: "..."}]
  pains            Json     @default("[]")    // [{title: "...", description: "..."}]
  features         Json     @default("[]")    // [{title: "...", description: "...", icon: "..."}]
  targetIndustries Json     @default("[]")    // [{name: "...", icon: "..."}]
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  pricingTiers     PricingTier[]
}

model PricingTier {
  id          Int      @id @default(autoincrement())
  productId   Int
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tierName    String   // start, business, pro
  price       Int
  currency    String   @default("KGS")
  description String
  features    Json     @default("[]")  // ["feature1", "feature2"]
  isPopular   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, tierName])
}

model CaseStudy {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  clientName  String
  productName String
  cost        String?
  timeline    String?
  result      String   @db.Text
  status      String   @default("completed")
  quote       String?  @db.Text
  quoteAuthor String?
  imageUrl    String?
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Application {
  id              Int      @id @default(autoincrement())
  name            String
  company         String?
  phone           String
  email           String?
  productInterest Json     @default("[]")
  message         String?  @db.Text
  status          String   @default("new")  // new, in_progress, closed
  source          String?
  utmParams       Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BlogPost {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  title       String
  content     String    @db.Text
  excerpt     String?   @db.Text
  imageUrl    String?
  videoUrl    String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AdminUser {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
  name     String
  role     String @default("admin")
}

model SiteSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String @db.Text
}

model Partner {
  id          Int      @id @default(autoincrement())
  name        String
  logoUrl     String   @default("")
  logoDarkUrl String   @default("")
  darkMode    String   @default("none")
  url         String   @default("")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
